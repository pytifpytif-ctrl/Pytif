{
  "name": "jiokoe",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "description": "Jiokoe — a commitment wallet. Lock your money, get it back on your own schedule.",
  "scripts": {
    "dev": "vite",
    "build": "npm run audit:prod && npm run pwa:icons && vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-10000}",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "serve": "14.2.6"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.13",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
