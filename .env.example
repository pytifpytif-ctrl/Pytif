# ---------------------------------------------------------------------------
# Wastel environment variables
# Copy to `.env` and fill in. The frontend only reads the VITE_* vars.
# The rest are configured as Supabase Edge Function secrets (see README).
# ---------------------------------------------------------------------------

# ---- Frontend (Vite) ----
# Leave these EMPTY to run the app in local demo mode (in-browser mock backend).
# Set them to connect the real Supabase backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Supabase CLI (used to link/push/deploy from the terminal) ----
SUPABASE_PROJECT_REF=             # the <ref> in dashboard URL .../project/<ref>
SUPABASE_DB_PASSWORD=             # Postgres password set when you created the project
SUPABASE_ACCESS_TOKEN=            # personal token: supabase.com/dashboard/account/tokens

# ---- Supabase (server / edge function secrets) ----
SUPABASE_URL=                     # https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Daraja / Mpesa ----
MPESA_ENV=sandbox                 # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=                  # STK push (C2B) till or paybill
MPESA_PASSKEY=                    # from Safaricom developer portal
MPESA_B2C_SHORTCODE=              # B2C disbursement shortcode (falls back to MPESA_SHORTCODE)
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=    # encrypted initiator password
MPESA_STK_CALLBACK_URL=           # https://<ref>.functions.supabase.co/stk-callback
MPESA_B2C_RESULT_URL=             # https://<ref>.functions.supabase.co/b2c-result
MPESA_B2C_QUEUE_TIMEOUT_URL=      # https://<ref>.functions.supabase.co/b2c-timeout

# ---- Africa's Talking (SMS) ----
AT_API_KEY=
AT_USERNAME=

# ---- App ----
APP_URL=
JWT_SECRET=
TZ=Africa/Nairobi                 # enforce EAT timezone
